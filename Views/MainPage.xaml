<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MultiLanguageApp.MainPage">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B1320" Offset="0.0"/>
            <GradientStop Color="#1C2541" Offset="0.5"/>
            <GradientStop Color="#3A506B" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <VerticalStackLayout Padding="20" Spacing="18">

        <CarouselView x:Name="LanguageCarousel"
                      HeightRequest="540"
                      Loop="True">

            <CarouselView.ItemTemplate>
                <DataTemplate>

                    <Frame CornerRadius="28"
                           Margin="15"
                           Padding="0"
                           HasShadow="True"
                           BackgroundColor="#FFFFFFEE">

                        <Frame.Shadow>
                            <Shadow Brush="Black"
                                    Opacity="0.25"
                                    Radius="20"
                                    Offset="0,12"/>
                        </Frame.Shadow>

                        <Grid>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCardTapped"/>
                            </Grid.GestureRecognizers>

                            <VerticalStackLayout Spacing="12">

                                <Image Source="{Binding ImageUrl}"
                                       HeightRequest="260"
                                       Aspect="AspectFill"/>

                                <VerticalStackLayout Padding="18" Spacing="8">

                                    <Label Text="{Binding Title}"
                                           FontSize="26"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           TextColor="#1B1B1B"/>

                                    <Label Text="{Binding Description}"
                                           FontSize="14"
                                           Opacity="0.75"
                                           HorizontalTextAlignment="Center"
                                           TextColor="#444"/>

                                </VerticalStackLayout>

                            </VerticalStackLayout>

                        </Grid>
                    </Frame>

                </DataTemplate>
            </CarouselView.ItemTemplate>

        </CarouselView>

        <IndicatorView x:Name="Indicator"
                       IndicatorColor="#8FA3BF"
                       SelectedIndicatorColor="#FFFFFF"
                       HorizontalOptions="Center"/>

        <HorizontalStackLayout Spacing="16"
                               HorizontalOptions="Center"
                               Margin="0,10,0,0">

            <Button Text="EN"
                    WidthRequest="140"
                    HeightRequest="45"
                    BackgroundColor="#4CC9F0"
                    TextColor="White"
                    CornerRadius="22"
                    FontAttributes="Bold"
                    Clicked="SetEnglish"/>

            <Button Text="ET"
                    WidthRequest="140"
                    HeightRequest="45"
                    BackgroundColor="#4361EE"
                    TextColor="White"
                    CornerRadius="22"
                    FontAttributes="Bold"
                    Clicked="SetEstonian"/>

        </HorizontalStackLayout>

    </VerticalStackLayout>

</ContentPage>